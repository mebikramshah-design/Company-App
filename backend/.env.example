# Server
NODE_ENV=development
PORT=5000
API_BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/company_app
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/company_app?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECRET=change_me_cookie_secret

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# SMTP (choose one provider)
# --- Gmail ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM_NAME=Company App
EMAIL_FROM_ADDRESS=no-reply@company.app

# --- SendGrid (alternative) ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxxxxxxx

# --- Mailgun (alternative) ---
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your_mailgun_password

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15555555555
TWILIO_VERIFY_SERVICE_SID=

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10
